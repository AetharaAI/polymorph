# Provider selection
AGENT_PROVIDER=openai
AGENT_MODEL=your-model-name
AGENT_ENABLE_FALLBACK=true
AGENT_FALLBACK_PROVIDER=openai_compat
AGENT_FALLBACK_BASE_URL=https://api.aetherpro.tech/v1
AGENT_FALLBACK_API_KEY=replace_me
AGENT_FALLBACK_MODEL=known-good-local-model
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic-compatible credentials
# PROVIDER_ANTHROPIC_API_KEY=replace_me
# PROVIDER_ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible credentials (when AGENT_PROVIDER=openai_compat)
# OPENAI_COMPAT_BASE_URL=https://api.aetherpro.tech/v1
# OPENAI_COMPAT_API_KEY=replace_me
# OPENAI_COMPAT_MODEL=
# OPENAI_COMPAT_ENABLE_THINKING=false
# OPENAI_COMPAT_LOG_REQUESTS=true
# OPENAI_COMPAT_LOG_FULL_PAYLOAD=false

# Unified gateway model aliases (legacy LiteLLM env names kept as model catalog aliases)
# LITELLM_MODEL_BASE_URL=https://api.aetherpro.tech/v1
# LITELLM_API_KEY=replace_me
# LITELLM_MODEL_NAME=model-1
# LITELLM_MODEL_NAMES=model-1,model-2,model-3

# Agent control knobs
MAX_AGENT_ITERATIONS=60
MAX_TOOL_CALLS_PER_ITERATION=12
MAX_TOOL_CALLS_PER_RUN=120
MAX_HISTORY_CHARS_FOR_MODEL=180000
AGENT_MAX_TOKENS=16384
AGENT_TEMPERATURE=1.0
STRICT_VERIFICATION_MODE=true
ENABLE_REPLAY_LOGS=true
DISABLED_TOOLS=
AGENT_REQUIRE_PLAN_FOR_PROJECTS=true
AGENT_PLAN_APPROVAL_MODE=manual
# AGENT_PLAN_APPROVAL_KEYWORDS=approve plan,plan approved,proceed with build
AGENT_SHELL_PROFILE=project
# AGENTS_RULES_PATH=/app/backend/AGENTS.md
# PYTHON_TOOL_MAX_TIMEOUT_SECONDS=180
# SHELL_TIMEOUT_SECONDS=60

# Prompt overrides
# SYSTEM_PROMPT_PATH=/app/backend/prompts/system_prompt.md
# TOOL_EVALUATION_PROMPT_PATH=/app/backend/prompts/tool_evaluation_prompt.md

# Runtime connection override storage
# RUNTIME_CONFIG_PATH=/app/backend/replays/runtime_config.json
# RUNTIME_CONFIG_KEY_PATH=/app/backend/replays/runtime_config.key
# RUNTIME_CONFIG_ENCRYPTION_KEY=   # optional Fernet key; if empty, a local key file is generated

# Voice services (optional)
# VOICE_AGENT_PROVIDER=openai_compat
# VOICE_AGENT_MODEL=omnicoder
# VOICE_AGENT_FALLBACK_MODEL=qwen3.5-9b
# VOICE_AGENT_MAX_TOKENS=512
# VOICE_AGENT_TEMPERATURE=0.6
# VOICE_REALTIME_TTS_BASE_URL=https://asr.example.com
# VOICE_REALTIME_TTS_MODEL=kokoro_realtime
# VOICE_REALTIME_TTS_VOICE=af_sky
#
# ASR_BASE_URL=https://asr.example.com
# ASR_API_KEY=replace_me
# ASR_MODEL=Systran/faster-whisper-large-v3
# ASR_TRANSCRIBE_PATH=/api/asr
# ASR_TIMEOUT_SECONDS=60
# ASR_HEALTH_TIMEOUT_SECONDS=3
# ASR_MAX_FILE_SIZE_BYTES=26214400
#
# TTS_BASE_URL=https://tts.example.com
# TTS_API_KEY=replace_me
# TTS_MODEL=your-tts-model
# TTS_TIMEOUT_SECONDS=60
#
# Direct multimodal audio model routing (optional)
# Use this when microphone audio should go directly to a multimodal chat model
# instead of being transcribed first.
# DIRECT_AUDIO_PROVIDER=openai_compat
# DIRECT_AUDIO_BASE_URL=https://api.aetherpro.tech/v1
# DIRECT_AUDIO_API_KEY=replace_me
# DIRECT_AUDIO_MODEL=phi-4-instruct
# PHI_4_INSTRUCT_MODEL_BASE_URL=https://api.aetherpro.tech/v1
# PHI_4_INSTRUCT_API_KEY=replace_me
# PHI_4_INSTRUCT_MODEL_NAME=phi-4-instruct
#
# Outreach / Profit Agent tooling (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_SSL=false
# SMTP_USE_STARTTLS=true
# SMTP_FROM_EMAIL=
# SMTP_FROM_NAME=AetherPro Outreach
# EMAIL_SEND_ENABLED=false
# EMAIL_ALLOWED_DOMAIN_SUFFIXES=aetherpro.us,aetherpro.tech
# PROFIT_SCRAPE_TIMEOUT_SECONDS=25
# PROFIT_SCRAPER_USER_AGENT=AetherPro-Agent/1.0 (+https://aetherpro.us)
# PROFIT_SCRAPE_ALLOW_INSECURE_RETRY=true

# Memory backends (optional overrides)
# MEMORY_NAMESPACE=polymorph
# REDIS_URL=redis://localhost:6379/0
# AETHER_MONGO_URI=mongodb://localhost:27017/aether_memory
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/db
# POSTGRES_SCHEMA=polymorph
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=

# CORS (optional)
# CORS_ALLOWED_ORIGINS=http://localhost:33333
# CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$
