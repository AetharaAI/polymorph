# PolyMorph complete env example
# Copy this file to `.env.polymorph` and replace placeholder secrets.
# This file is intended as a clean reference and should not contain real keys.

# =========================
# Namespace isolation
# =========================
MEMORY_NAMESPACE=polymorph
HARNESS_NAMESPACE=polymorph
AETHER_MONGO_DB=aether_memory
POSTGRES_SCHEMA=polymorph
QDRANT_COLLECTION_PREFIX=polymorph

# =========================
# Core provider routing
# =========================
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-5.4
AGENT_ENABLE_FALLBACK=true
AGENT_FALLBACK_PROVIDER=openai_compat
AGENT_FALLBACK_BASE_URL=https://api.aetherpro.tech/v1
AGENT_FALLBACK_API_KEY=replace_me
AGENT_FALLBACK_MODEL=qwen3.5-35b
OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096
INCLUDE_THINKING_IN_CONTEXT=false

OPENAI_COMPAT_BASE_URL=https://api.aetherpro.tech/v1
OPENAI_COMPAT_API_KEY=replace_me
OPENAI_COMPAT_MODEL=qwen3.5-35b
OPENAI_COMPAT_CONTEXT_WINDOW=
OPENAI_COMPAT_TIMEOUT_SECONDS=420
OPENAI_COMPAT_READ_TIMEOUT_SECONDS=420
OPENAI_COMPAT_CONNECT_TIMEOUT_SECONDS=20
OPENAI_COMPAT_WRITE_TIMEOUT_SECONDS=30
OPENAI_COMPAT_MAX_RETRIES=2
OPENAI_COMPAT_LOG_REQUESTS=true
OPENAI_COMPAT_LOG_FULL_PAYLOAD=false
OPENAI_COMPAT_STREAM=true
OPENAI_COMPAT_ENABLE_THINKING=false
OPENAI_COMPAT_TOP_P=0.9
OPENAI_COMPAT_PRESENCE_PENALTY=0.2
OPENAI_COMPAT_FREQUENCY_PENALTY=0.1

# Optional direct vendor keys (fallback or eval use)
OPENAI_API_KEY=replace_me
PROVIDER_ANTHROPIC_API_KEY=replace_me
PROVIDER_ANTHROPIC_BASE_URL=https://api.anthropic.com

# =========================
# Unified gateway model catalog
# =========================
LITELLM_MODEL_BASE_URL=https://api.aetherpro.tech/v1
LITELLM_API_KEY=replace_me
LITELLM_MODEL_NAME=qwen3.5-35b
LITELLM_MODEL_NAMES=qwen3.5-35b,qwen3.5-9b,qwen3.5-4b,jan-code-4b,openai/qwen3.5-122

# =========================
# Memory + retrieval infra
# =========================
REDIS_URL=redis://:replace_me@100.87.16.38:6380
AETHER_MONGO_URI=mongodb://user:pass@100.87.16.38:27018/aether_memory?authSource=aether_memory
POSTGRES_DSN=postgresql://user:pass@100.87.16.38:5440/operations
QDRANT_HOST=100.87.16.38
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_URL=http://100.87.16.38:6333
QDRANT_GRPC_ENABLED=false

BGE_EMBED_URL=https://embed.aetherpro.us/v1/embeddings
BGE_RERANK_URL=https://embed.aetherpro.us/rerank
BGE_EMBED_MODEL=bge-m3
BGE_EMBED_DIM=1024
EMBEDDING_API_URL=https://embed.aetherpro.us/v1/embeddings
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMS=1024
RERANKER_API_URL=https://embed.aetherpro.us/rerank

VECTOR_SEARCH_ENABLED=true
SEARCH_TEXT_WEIGHT=0.3
SEARCH_VECTOR_WEIGHT=0.7
MEMORY_DECAY_HALF_LIFE=30
MEMORY_MMR_LAMBDA=0.7
AGENTIC_FLUSH_ENABLED=true

# =========================
# Search / web keys
# =========================
TAVILY_API_KEY=replace_me
TAVILY_TIMEOUT_SECONDS=20
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=replace_me
BRAVE_SEARCH_API_KEY=replace_me

# =========================
# Voice endpoints
# =========================
ASR_BASE_URL=https://asr.aetherpro.us
ASR_API_KEY=replace_me
ASR_MODEL=Systran/faster-whisper-large-v3
# Optional override if your ASR gateway only exposes a non-default path (e.g. /api/asr)
ASR_TRANSCRIBE_PATH=
ASR_TIMEOUT_SECONDS=60
ASR_HEALTH_TIMEOUT_SECONDS=3
ASR_MAX_FILE_SIZE_BYTES=26214400

TTS_BASE_URL=https://tts.aetherpro.us
TTS_API_KEY=replace_me
TTS_MODEL=replace_me
TTS_TIMEOUT_SECONDS=60

# Direct multimodal audio model path (microphone -> model, no ASR intermediary)
DIRECT_AUDIO_PROVIDER=openai_compat
DIRECT_AUDIO_BASE_URL=https://api.aetherpro.tech/v1
DIRECT_AUDIO_API_KEY=replace_me
DIRECT_AUDIO_MODEL=phi-4-instruct
# Convenience aliases; the backend will use these if DIRECT_AUDIO_* is unset
PHI_4_INSTRUCT_MODEL_BASE_URL=https://api.aetherpro.tech/v1
PHI_4_INSTRUCT_API_KEY=replace_me
PHI_4_INSTRUCT_MODEL_NAME=phi-4-instruct

# Outreach / Profit Agent tooling
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AetherPro Outreach
# Keep false until you explicitly want agent-driven sending
EMAIL_SEND_ENABLED=false
# Restrict live sends to your own domains by default
EMAIL_ALLOWED_DOMAIN_SUFFIXES=aetherpro.us,aetherpro.tech
PROFIT_SCRAPE_TIMEOUT_SECONDS=25
PROFIT_SCRAPER_USER_AGENT=AetherPro-Agent/1.0 (+https://aetherpro.us)
PROFIT_SCRAPE_ALLOW_INSECURE_RETRY=true

# =========================
# Optional provider/API keys
# =========================
ANTHROPIC_API_KEY=replace_me
OPENROUTER_API_KEY=replace_me
XAI_API_KEY=replace_me
COHERE_API_KEY=replace_me
GEMINI_API_KEY=replace_me
NVIDIA_API_KEY=replace_me
HUGGINGFACEHUB_API_KEY=replace_me
HF_TOKEN=replace_me
MINIMAX_API_KEY=replace_me
SECONDARY_MODEL_API_KEY=replace_me
OLLAMA_API_KEY=replace_me
SPEECHMATICS_API_KEY=replace_me
PYPL_API_KEY=replace_me

# =========================
# Agent/runtime behavior
# =========================
MAX_AGENT_ITERATIONS=60
MAX_TOOL_CALLS_PER_ITERATION=12
MAX_TOOL_CALLS_PER_RUN=120
MAX_HISTORY_CHARS_FOR_MODEL=180000
STRICT_VERIFICATION_MODE=true
ENABLE_REPLAY_LOGS=true
DISABLED_TOOLS=
AGENT_REQUIRE_PLAN_FOR_PROJECTS=true
AGENT_PLAN_APPROVAL_MODE=manual
AGENT_SHELL_PROFILE=project
MAX_TEXT_BLOCK_CHARS_FOR_CONTEXT=12000
MAX_TOOL_RESULT_CHARS_FOR_CONTEXT=8000
SSE_EVENT_WAIT_TIMEOUT_SECONDS=10
SSE_HEARTBEAT_SECONDS=8

# =========================
# Skills and runtime config
# =========================
SKILLS_ENABLED=true
SKILLS_REGISTRY_PATH=/app/backend/SKILLS.md
SKILLS_DIRS=
SKILLS_MAX_ACTIVE=5
SKILLS_MIN_SCORE=0.15
SKILLS_MAX_CHARS_PER_SKILL=180000
SKILLS_MAX_TOTAL_CHARS=500000

RUNTIME_CONFIG_PATH=/app/backend/replays/runtime_config.json
RUNTIME_CONFIG_KEY_PATH=/app/backend/replays/runtime_config.key
RUNTIME_CONFIG_ENCRYPTION_KEY=

# =========================
# Optional app/network config
# =========================
CORS_ALLOWED_ORIGINS=http://localhost:33333
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$
AGENTS_RULES_PATH=/app/backend/AGENTS.md
AGENT_IDENTITY_DIR=/app/agent_identity
AGENT_NAME=AetherOps Agent

# =========================
# Tool timeout controls
# =========================
PYTHON_TOOL_MAX_TIMEOUT_SECONDS=180
SHELL_TIMEOUT_SECONDS=60
PROJECT_COMMAND_TIMEOUT_SECONDS=1200
PROJECT_HTTP_TIMEOUT_SECONDS=30
PROJECT_RUNNER_MAX_LOG_LINES=800
PROJECT_RUNNER_MAX_OUTPUT_CHARS=160000
WORKSPACE_DIAGNOSTIC_MAX_ITEMS=200
WORKSPACE_TSC_OUTPUT_MAX_CHARS=80000
